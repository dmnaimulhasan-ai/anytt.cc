# Lovable/Netlify Redirects Configuration
# SEO Optimized - No redirect chains, clean URLs

# Force HTTPS and www normalization (handled by Netlify)
# All traffic goes to https://anytt.cc (canonical)

# Static files - serve directly with forced 200 (bypass SPA)
/sitemap.xml    /sitemap.xml    200!
/robots.txt     /robots.txt     200!

# Remove trailing slashes - DIRECT redirect (no chains)
/tiktok-downloader/ /tiktok-downloader 301!
/faq/ /faq 301!
/blog/ /blog 301!
/about/ /about 301!
/privacy-policy/ /privacy-policy 301!
/terms-of-service/ /terms-of-service 301!
/dmca/ /dmca 301!

# Legacy URL redirects - DIRECT to final destination (no chains)
/facebook-downloader /tiktok-downloader 301!
/facebook-downloader/* /tiktok-downloader 301!
/youtube-downloader /tiktok-downloader 301!
/youtube-downloader/* /tiktok-downloader 301!
/save /tiktok-downloader 301!
/tiktok /tiktok-downloader 301!
/tt /tiktok-downloader 301!

# New language routes - trailing slash redirects
/tr/tiktok-indir/ /tr/tiktok-indir 301!
/th/tiktok-download/ /th/tiktok-download 301!
/vi/tai-tiktok/ /vi/tai-tiktok 301!

